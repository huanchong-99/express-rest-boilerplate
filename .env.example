NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# Auth
JWT_SECRET=change-me-to-a-secure-random-string
JWT_EXPIRATION_MINUTES=15

# Database (MongoDB — original Express app)
MONGO_URI=mongodb://localhost:27017/express-rest-es2017-boilerplate
MONGO_URI_TESTS=mongodb://localhost:27017/express-rest-es2017-boilerplate-test

# Database (PostgreSQL — Rust migration)
DATABASE_URL=postgres://user:password@localhost:5432/express_rest_boilerplate
